    galleryIndex = index;
    renderGalleryItem();
    galleryModal.classList.add('show');
  };

  const closeGallery = () => {
    if (!galleryModal) return;
    galleryModal.classList.remove('show');
  };

  const saveDetail = async (event) => {
    event.preventDefault();
    if (!currentDetail) return;
    setAlert('');
    const formData = new FormData(detailForm);
    const payload = Object.fromEntries(formData.entries());
    payload.replacement_sent = detailForm.replacement_sent ? detailForm.replacement_sent.checked : false;
    if (!/^[^@\s]+@[^@\s]+\.(pl|com)$/i.test(payload.email || '')) {
      setAlert('Email musi kończyć się na .pl lub .com');
      return;
    }
    if (!/^[0-9]+$/.test(payload.phone || '')) {
      setAlert('Telefon może zawierać tylko cyfry');
      return;
    }
    try {
      const res = await fetch(`/api/reklamacje/${currentDetail.id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (!res.ok || !data.success) throw new Error(data.error || 'Nie udało się zapisać');
      await fetchClaims();
      await openDetail(currentDetail.id);
      setAlert('Zapisano zmiany.', 'success');
    } catch (err) {
      setAlert(err.message || 'Błąd zapisu');
    }
  };

  const addDetailPart = async () => {
    if (!currentDetail) return;
    const name = partName.value.trim();
    if (!name) return;
    const res = await fetch(`/api/reklamacje/${currentDetail.id}/parts`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ part_name: name }),
    });
    const data = await res.json();
    if (!res.ok || !data.success) {
      setAlert(data.error || 'Nie udało się dodać części');
      return;
    }
    partName.value = '';
    // Szybka aktualizacja lokalna bez dociągania całych szczegółów
    const newPart = data.item ? { ...data.item, sent: !!data.item.sent } : null;
    if (newPart) {
      currentDetail.parts = [...(currentDetail.parts || []), newPart];
      renderDetailParts(currentDetail.parts);
      syncMissingWithParts();
      return;
    }
    // Fallback: gdyby API nie zwróciło elementu
    const partsRes = await fetch(`/api/reklamacje/${currentDetail.id}`);
    const partsData = await partsRes.json();
    if (partsData.success && partsData.item) {
      currentDetail.parts = partsData.item.parts || [];
      renderDetailParts(currentDetail.parts);
      syncMissingWithParts();
    }
  };

  const deleteDetailPart = async (id) => {
    if (!currentDetail) return;
    const part = (currentDetail.parts || []).find(p => String(p.id) === String(id));
    // Jeśli część była w "wysłanych", cofamy do zgłoszonych zamiast usuwać
    if (part && part.sent) {
      await movePartToSent(id, false);
      return;
    }
    // Najpierw zdejmij lokalnie z listy (UI zawsze reaguje)
    currentDetail.parts = (currentDetail.parts || []).filter(p => String(p.id) !== String(id));
    renderDetailParts(currentDetail.parts);
    syncMissingWithParts();
    // Spróbuj skasować na serwerze w tle (bez blokowania UI)
    try {
      const res = await fetch(`/api/reklamacje/${currentDetail.id}/parts/${id}`, { method: 'DELETE' });
      if (!res.ok) {
        console.warn('DELETE part failed', res.status);
      }
    } catch (e) {
      console.warn('DELETE part network error', e);
    }
  };

  const movePartToSent = async (id, sent = true) => {
    if (!currentDetail) return;
    // Zmień status lokalnie
    currentDetail.parts = (currentDetail.parts || []).map(p =>
      String(p.id) === String(id) ? { ...p, sent } : p
    );
    renderDetailParts(currentDetail.parts);
    syncMissingWithParts();
    // Spróbuj zapisać na serwerze w tle (bez blokowania UI)
    try {
      const res = await fetch(`/api/reklamacje/${currentDetail.id}/parts/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sent }),
      });
      const data = await res.json().catch(() => ({}));
      if (!res.ok || (data && data.success === false)) {
        console.warn('PUT part sent flag failed', res.status, data);
      }
    } catch (e) {
      console.warn('PUT part network error', e);
    }
  };

  const renderFilePreviews = (container) => {
    container.innerHTML = '';
    if (!selectedFiles || !selectedFiles.length) return;
    selectedFiles.forEach((file, index) => {
      const wrapper = document.createElement('div');
      wrapper.className = 'upload-thumb';
      wrapper.dataset.fileIndex = index;
      if (file.type.startsWith('image/')) {
        const img = document.createElement('img');
        img.src = URL.createObjectURL(file);
        img.onload = () => URL.revokeObjectURL(img.src);
        wrapper.appendChild(img);
        const pop = document.createElement('div');
        pop.className = 'upload-pop';
        const big = document.createElement('img');
        big.src = img.src;
        pop.appendChild(big);
        wrapper.appendChild(pop);
      } else if (file.type.startsWith('video/')) {
        const video = document.createElement('video');
        video.src = URL.createObjectURL(file);
        video.onloadeddata = () => URL.revokeObjectURL(video.src);
        video.muted = true;
        video.playsInline = true;
        wrapper.appendChild(video);
        const pop = document.createElement('div');
        pop.className = 'upload-pop';
        const big = document.createElement('video');
        big.src = video.src;
        big.muted = true;
        big.playsInline = true;
        big.autoplay = true;
        big.loop = true;
        pop.appendChild(big);
        wrapper.appendChild(pop);
      } else {
        wrapper.textContent = file.name.slice(0, 12);
      }
      // Przycisk usuwania
      const removeBtn = document.createElement('button');
      removeBtn.type = 'button';
      removeBtn.className = 'btn-close';
      removeBtn.style.position = 'absolute';
      removeBtn.style.top = '4px';
      removeBtn.style.right = '4px';
      removeBtn.style.background = 'rgba(255,255,255,0.8)';
      removeBtn.style.borderRadius = '50%';
      removeBtn.style.width = '20px';
      removeBtn.style.height = '20px';
      removeBtn.style.fontSize = '12px';
      removeBtn.title = 'Usuń plik';
      removeBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        selectedFiles.splice(index, 1);
        renderFilePreviews(container);
      });
      wrapper.style.position = 'relative';
      wrapper.appendChild(removeBtn);
      container.appendChild(wrapper);
    });
  };


  const renderUploadedThumbs = (items, claimId) => {
