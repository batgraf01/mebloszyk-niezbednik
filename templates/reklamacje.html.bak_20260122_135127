  // Skala dni:
  // 0-1 = nowe (zielone), 2-4 = średnie (żółte), 5+ = stare (czerwone)
  const DAY_SCALE = { newMax: 1, midMax: 4 };
  const renderDayIcon = (days) => {
    const n = Number(days) || 0;
    if (n <= DAY_SCALE.newMax) {
      return `<i class="bi bi-bar-chart-fill" style="color: #22c55e;"></i>`;
    }
    if (n <= DAY_SCALE.midMax) {
      return `<i class="bi bi-bar-chart-fill" style="color: #f59e0b;"></i>`;
    }
    return `<i class="bi bi-bar-chart-fill" style="color: #ef4444;"></i>`;
  };

  const getStatusStyle = (status) => {
    const s = (status || '').toLowerCase();
    if (s.includes('nowa')) return { bg: '#3b82f6', border: '#3b82f6' };
    if (s.includes('w trakcie')) return { bg: '#f59e0b', border: '#f59e0b' };
    if (s.includes('ruch klienta') || s.includes('czekamy na informację')) return { bg: '#8b5cf6', border: '#8b5cf6' };
    if (s.includes('zrealizowana') || s.includes('zakończone') || s.includes('zamknięta')) return { bg: '#22c55e', border: '#22c55e' };
    if (s.includes('odrzucon')) return { bg: '#ef4444', border: '#ef4444' };
    return { bg: '#94a3b8', border: '#94a3b8' };
  };

  const renderPage = () => {
    injectClaimStyles();
    const totalPages = Math.max(1, Math.ceil(filteredItems.length / pageSize));
    if (currentPage > totalPages) currentPage = totalPages;
    const start = (currentPage - 1) * pageSize;
    const end = start + pageSize;
    const pageItems = filteredItems.slice(start, end);
    pageInfo.textContent = `${currentPage}/${totalPages}`;
    prevPage.disabled = currentPage === 1;
    nextPage.disabled = currentPage === totalPages;

    if (!pageItems.length) {
      claimsBody.innerHTML = '<tr><td colspan="8" class="text-center text-muted py-4">Brak reklamacji</td></tr>';
      return;
    }

    claimsBody.innerHTML = pageItems.map(item => {
      const statusStyle = getStatusStyle(item.status);
      const desc = (item.description || '').trim();
      const descPreview = desc ? escapeHtml(desc.slice(0, 200)) : '';
      return `
      <tr class="claim-row" data-id="${item.id}" style="border-left: 2px solid ${statusStyle.border};">
        <td class="text-center"><i class="bi bi-caret-right-fill claim-caret-icon" style="color: rgb(174 174 174);"></i></td>
        <td class="fw-semibold text-primary">
          <div class="d-flex align-items-center gap-2">
            <span class="d-flex align-items-center">${renderDayIcon(item.days_open)}</span>
            <span>${item.days_open} dni</span>
          </div>
        </td>
        <td>
          <span class="status-pill" style="display:inline-block; min-width:120px; text-align:center; border-radius:4px; background:${statusStyle.bg}; color:#fff; font-weight:400; font-size:11px;">
            ${escapeHtml((item.status || '').replace('Czekamy na informację', 'Czekamy na info'))}
          </span>
        </td>
        <td>
          <div class="text-muted" style="font-size:10px;">
            ${item.last_note_date ? formatDateShort(item.last_note_date) : ''}
          </div>
          <div style="font-size:11px;">
            ${escapeHtml((item.last_note_text || '').slice(0, 120))}
          </div>
        </td>
        <td>${escapeHtml(item.order_no)}</td>
        <td>
          <div class="fw-semibold">${escapeHtml(item.customer_name)}</div>
          <div class="text-muted small">${escapeHtml(item.email)}</div>
        </td>
        <td>${escapeHtml(item.type)}</td>
        <td>${escapeHtml(formatDate(item.reported_at))}</td>
        <td>
          <button type="button" class="btn btn-sm btn-outline-secondary claim-delete" data-id="${item.id}" title="Usuń reklamację">
            <i class="bi bi-trash3-fill"></i>
          </button>
        </td>
      </tr>
    `;}).join('');
  };

  const applyFilters = () => {
    const query = (searchInput.value || '').toLowerCase().trim();
    const status = statusFilter.value;
    const type = typeFilter.value;
    filteredItems = items.filter(item => {
      if (status && item.status !== status) return false;
      if (type && item.type !== type) return false;
      if (!query) return true;
      return [item.order_no, item.email].join(' ').toLowerCase().includes(query);
    });
    currentPage = 1;
    renderPage();
  };

  const fetchClaims = async () => {
    setAlert('');
    claimsBody.innerHTML = '<tr><td colspan="8" class="text-center text-muted py-4">Ładowanie...</td></tr>';
    try {
      const res = await fetch('/api/reklamacje');
      const contentType = res.headers.get('content-type') || '';
      if (!contentType.includes('application/json')) {
        throw new Error(`Błędna odpowiedź API (${res.status}).`);
      }
      const data = await res.json();
      if (!data.success) throw new Error(data.error || 'Nie udało się pobrać danych');
      items = Array.isArray(data.items) ? data.items : [];
      meta.statuses = Array.isArray(data.statuses) ? data.statuses : [];
      meta.types = Array.isArray(data.types) ? data.types : [];
      meta.decisions = Array.isArray(data.decisions) ? data.decisions : [];
      if (updatedAt) {
        updatedAt.textContent = data.updated_at ? formatDate(data.updated_at) : '-';
      }

      if (statusFilter && meta.statuses.length > 0) {
        fillSelect(statusFilter, meta.statuses, 'Wszystkie statusy');
      }
      if (typeFilter && meta.types.length > 0) {
        fillSelect(typeFilter, meta.types, 'Wszystkie typy');
      }
      claimForm.querySelector('select[name="type"]').innerHTML = '<option value="">Wybierz</option>' +
        meta.types.map(opt => `<option value="${escapeHtml(opt)}">${escapeHtml(opt)}</option>`).join('');
      detailForm.querySelector('select[name="type"]').innerHTML = meta.types.map(opt => `<option value="${escapeHtml(opt)}">${escapeHtml(opt)}</option>`).join('');
      detailForm.querySelector('select[name="status"]').innerHTML = meta.statuses.map(opt => `<option value="${escapeHtml(opt)}">${escapeHtml(opt)}</option>`).join('');
      detailForm.querySelector('select[name="decision"]').innerHTML = [''].concat(meta.decisions).map(opt =>
        `<option value="${escapeHtml(opt)}">${opt ? escapeHtml(opt) : 'Brak'}</option>`).join('');

      applyFilters();
    } catch (err) {
      setAlert(err.message || 'Błąd pobierania');
      claimsBody.innerHTML = '<tr><td colspan="8" class="text-center text-muted py-4">Brak danych</td></tr>';
    }
  };

  const uploadAttachments = async (claimId, files) => {
    if (!files || !files.length) return;
    const formData = new FormData();
    [...files].forEach(file => formData.append('files', file));
    const res = await fetch(`/api/reklamacje/${claimId}/attachments`, {
      method: 'POST',
      body: formData,
    });
    const contentType = res.headers.get('content-type') || '';
    if (!contentType.includes('application/json')) {
      const text = await res.text();
      throw new Error(`Błąd serwera (${res.status}): ${text.substring(0, 100)}`);
    }
    const data = await res.json();
    if (!res.ok || !data.success) {
      throw new Error(data.error || 'Nie udało się dodać załączników');
    }
  };

  const fetchAttachments = async (claimId) => {
    const res = await fetch(`/api/reklamacje/${claimId}/attachments`);
    const contentType = res.headers.get('content-type') || '';
    if (!contentType.includes('application/json')) {
      const text = await res.text();
      throw new Error(`Błąd serwera (${res.status}): ${text.substring(0, 100)}`);
    }
    const data = await res.json();
    if (!res.ok || !data.success) {
      throw new Error(data.error || 'Nie udało się pobrać załączników');
    }
    return Array.isArray(data.items) ? data.items : [];
  };

  const uploadAttachmentsWithProgress = (claimId, files) => new Promise((resolve, reject) => {
    if (!files || !files.length) return resolve([]);
    const formData = new FormData();
    [...files].forEach(file => formData.append('files', file));
    const xhr = new XMLHttpRequest();
    xhr.open('POST', `/api/reklamacje/${claimId}/attachments`);
    xhr.upload.onprogress = (event) => {
      if (!event.lengthComputable) return;
      const pct = Math.round((event.loaded / event.total) * 100);
      claimUploadProgress.classList.remove('d-none');
      claimUploadBar.style.width = `${pct}%`;
      claimUploadBar.textContent = `${pct}%`;
    };
    xhr.onload = () => {
      claimUploadProgress.classList.add('d-none');
      if (xhr.status >= 200 && xhr.status < 300) {
        try {
          const contentType = xhr.getResponseHeader('content-type') || '';
          if (!contentType.includes('application/json')) {
            return reject(new Error(`Błąd serwera (${xhr.status}): Otrzymano HTML zamiast JSON`));
          }
          const data = JSON.parse(xhr.responseText);
          if (!data.success) return reject(new Error(data.error || 'Upload nieudany'));
          return resolve(data.items || []);
        } catch (err) {
          return reject(new Error(`Błąd parsowania odpowiedzi: ${err.message}`));
        }
      }
      // Dla błędów HTTP zwróć szczegóły
      try {
        const contentType = xhr.getResponseHeader('content-type') || '';
        if (contentType.includes('application/json')) {
          const data = JSON.parse(xhr.responseText);
          return reject(new Error(data.error || `Upload nieudany (${xhr.status})`));
        }
      } catch (e) {
        // Ignoruj błędy parsowania przy błędzie HTTP
      }
      return reject(new Error(`Upload nieudany (HTTP ${xhr.status})`));
    };
    xhr.onerror = () => reject(new Error('Upload nieudany'));
    xhr.send(formData);
  });

  const submitClaim = async (event) => {
    event.preventDefault();
    setAlert('');
    syncHidden();
    const formData = new FormData(claimForm);
    const payload = Object.fromEntries(formData.entries());
    if (!/^[^@\s]+@[^@\s]+\.(pl|com)$/i.test(payload.email || '')) {
      setAlert('Email musi kończyć się na .pl lub .com');
      return;
    }
    if (!/^[0-9]+$/.test(payload.phone || '')) {
      setAlert('Telefon może zawierać tylko cyfry');
      return;
    }
    try {
      const res = await fetch('/api/reklamacje', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const contentType = res.headers.get('content-type') || '';
      if (!contentType.includes('application/json')) {
        throw new Error(`Błędna odpowiedź API (${res.status}).`);
      }
      const data = await res.json();
      if (!res.ok || !data.success) throw new Error(data.error || 'Nie udało się zapisać');
      // Użyj selectedFiles zamiast bezpośrednio z input
      if (selectedFiles && selectedFiles.length) {
        // Konwertuj File[] na FileList-like object dla uploadAttachmentsWithProgress
        const dataTransfer = new DataTransfer();
        selectedFiles.forEach(file => dataTransfer.items.add(file));
        const files = dataTransfer.files;
        await uploadAttachmentsWithProgress(data.item.id, files);
        const allUploaded = await fetchAttachments(data.item.id);
        console.log('Fetched attachments:', allUploaded.length);
        renderUploadedThumbs(allUploaded, data.item.id);
      } else {
        claimFilesGallery.innerHTML = '';
      }
      claimForm.reset();
      selectedFiles = []; // Wyczyść listę wybranych plików
      claimFilesGallery.innerHTML = ''; // Wyczyść galerię
      claimUploadProgress.classList.add('d-none');
      claimUploadBar.style.width = '0%';
      claimUploadBar.textContent = '0%';
      if (window.bootstrap) {
        bootstrap.Collapse.getOrCreateInstance(document.getElementById('claimFormWrap')).hide();
      }
      await fetchClaims();
      setAlert('Dodano reklamację.', 'success');
    } catch (err) {
      setAlert(err.message || 'Błąd zapisu');
    }
  };

  const formatDateShort = (iso) => {
    if (!iso) return '';
    try {
      const date = new Date(iso);
      if (Number.isNaN(date.getTime())) return iso;
      return date.toLocaleDateString('pl-PL');
    } catch {
      return iso;
    }
  };

  const openDetail = async (id) => {
    // Jeśli kliknięto w już otwartą reklamację, zamknij ją
    if (currentDetail && currentDetail.id === id && !detailCard.classList.contains('d-none')) {
