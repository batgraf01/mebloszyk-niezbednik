  const applyRocketData = (data) => {
    if (!data || typeof data !== 'object') return;
    openClaimForm();
    setFieldValue(getClaimField('customer_name'), data.fullName || data.customer_name || '');
    setFieldValue(getClaimField('email'), data.email || '');
    setFieldValue(getClaimField('phone'), data.phone || '');
    setFieldValue(getClaimField('order_no'), data.orderId || data.order_no || '');
    setFieldValue(getClaimField('purchase_date'), toDateInputValue(data.purchaseDate || data.purchase_date || ''));
  };

  const decodeMrData = (raw) => {
    if (!raw) return null;
    try {
      const json = decodeURIComponent(escape(atob(raw)));
      const data = JSON.parse(json);
      return data && typeof data === 'object' ? data : null;
    } catch (err) {
      return null;
    }
  };

  const getMrDataFromUrl = () => {
    const params = new URLSearchParams(window.location.search || '');
    const direct = {
      fullName: params.get('mr_name') || '',
      email: params.get('mr_email') || '',
      phone: params.get('mr_phone') || '',
      orderId: params.get('mr_order') || '',
      purchaseDate: params.get('mr_date') || ''
    };
    if (direct.fullName || direct.email || direct.phone || direct.orderId || direct.purchaseDate) {
      return direct;
    }
    const q = params.get('mr_data');
    if (q) return decodeMrData(q);
    const h = (window.location.hash || '').trim();
    const m = h.match(/^#mr_data=(.+)$/i);
    if (m) return decodeMrData(m[1]);
    return null;
  };

  const applyFromUrlIfPresent = () => {
    const data = getMrDataFromUrl();
    if (!data) return;
    applyRocketData(data);
    fullscreenNotice('Zrobione');
    setAlert('Wklejono dane z Rakiety do formularza.', 'success');
    // Clear hash/query to avoid re-applying on refresh
    if (window.history && window.history.replaceState) {
      const cleanUrl = window.location.pathname + window.location.search
        .replace(/([?&])mr_data=[^&]+(&|$)/, '$1')
        .replace(/([?&])mr_name=[^&]+(&|$)/, '$1')
        .replace(/([?&])mr_email=[^&]+(&|$)/, '$1')
        .replace(/([?&])mr_phone=[^&]+(&|$)/, '$1')
        .replace(/([?&])mr_order=[^&]+(&|$)/, '$1')
        .replace(/([?&])mr_date=[^&]+(&|$)/, '$1')
