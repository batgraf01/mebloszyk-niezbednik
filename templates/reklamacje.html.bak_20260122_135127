{% extends "base_panel.html" %}
{% block title %}Reklamacje{% endblock %}

{% block content %}
<!-- MVP reklamacje: nowe pola i szczegoly -->
<div class="card page-rozmiary">
  <div class="card-body">
    <div class="d-flex flex-wrap align-items-center justify-content-center gap-2 mb-4 controls-row">
      <div class="input-group search-group search-control">
        <span class="input-group-text"><i class="bi bi-search"></i></span>
        <input id="searchInput" type="search" class="form-control search-input controls-input" placeholder="Wyszukaj po numerze zamówienia lub emailu" autocomplete="off">
      </div>
      <button class="btn btn-primary btn-sm" data-bs-toggle="collapse" data-bs-target="#claimFormWrap"><i class="bi bi-plus-lg"></i> Zgłoszenie</button>
      <button id="rocketSearchBtn" class="btn btn-success btn-sm"><i class="bi bi-stars"></i> Szukaj</button>
      <button id="refreshBtn" class="btn btn-secondary btn-sm btn-search"><i class="bi bi-arrow-clockwise"></i> Odśwież</button>
      <select id="statusFilter" class="form-select form-select-sm status-filter status-filter-sm controls-select"></select>
      <select id="typeFilter" class="form-select form-select-sm status-filter status-filter-sm controls-select"></select>
    </div>

    <div id="alertBox" class="alert alert-danger d-none" role="alert"></div>

    <div class="collapse mb-3" id="claimFormWrap">
      <div class="card card-inner">
        <div class="card-body">
          <form id="claimForm" class="row g-3">
            <div class="col-12">
              <div class="row g-3 section-wrap section-row">
                <!-- Box 1: Imię i nazwisko, Email, Telefon -->
                <div class="col-12 col-md-4">
                  <div class="section-card h-100">
                    <div class="row g-3">
                      <div class="col-12">
                        <div class="mui-standard-field">
                          <label class="mui-label">Imię i nazwisko</label>
                          <input name="customer_name" type="text" class="mui-input-standard" placeholder="Imię i nazwisko" required>
                        </div>
                      </div>
                      <div class="col-12">
                        <div class="mui-standard-field">
                          <label class="mui-label">Email</label>
                          <input name="email" type="email" class="mui-input-standard" placeholder="Email (kończy się na .pl lub .com)" pattern="^[^@\s]+@[^@\s]+\.(pl|com)$" required>
                        </div>
                      </div>
                      <div class="col-12">
                        <div class="mui-standard-field">
                          <label class="mui-label">Telefon</label>
                          <input name="phone" type="text" class="mui-input-standard" placeholder="Telefon (tylko cyfry)" inputmode="numeric" pattern="^[0-9]+$" required>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
                <!-- Box 2: Zamówienie, Daty, Typ reklamacji -->
                <div class="col-12 col-md-4">
                  <div class="section-card h-100">
                    <div class="row g-3">
                      <div class="col-12">
                        <div class="mui-standard-field">
                          <label class="mui-label">Zamówienie:</label>
                          <input name="order_no" type="text" class="mui-input-standard" placeholder="Numer zamówienia" required>
                        </div>
                      </div>
                      <div class="col-6">
                        <div class="mui-standard-field">
                          <label class="mui-label">Data zakupu</label>
                          <input name="purchase_date" type="date" class="mui-input-standard" placeholder="Data zakupu">
                        </div>
                      </div>
                      <div class="col-6">
                        <div class="mui-standard-field">
                          <label class="mui-label">Data zgłoszenia</label>
                          <input name="reported_at" type="date" class="mui-input-standard" placeholder="Data zgłoszenia" required>
                        </div>
                      </div>
                      <div class="col-12">
                        <div class="mui-standard-field">
                          <label class="mui-label">Typ reklamacji</label>
                          <select name="type" class="mui-input-standard" required>
                            <option value="">Typ reklamacji</option>
                          </select>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
                <!-- Box 3: Produkt, Części -->
                <div class="col-12 col-md-4">
                  <div class="section-card h-100">
                    <div class="row g-3">
                      <div class="col-12">
                        <div class="mui-standard-field">
                          <label class="mui-label">produkt</label>
                          <select name="product_model" class="mui-input-standard" required>
                            <option value="">Model / wariant produktu</option>
                            <option value="Pergola">Pergola</option>
                            <option value="Domek">Domek</option>
                            <option value="Carport">Carport</option>
                          </select>
                        </div>
                      </div>
                      <div class="col-12">
                        <div class="mui-standard-field">
                          <label class="mui-label">Części</label>
                          <input id="partsInput" type="text" class="mui-input-standard parts-input-claim" placeholder="Wpisz kod/nazwę i Enter (np. DG1, MH56, drzwi)">
                        </div>
                        <button id="addPartBtnForm" type="button" class="btn btn-outline-primary mt-2">+ Dodaj</button>
                      </div>
                      <div class="col-12">
                        <div id="partsChips" class="parts-chips mt-2"></div>
                        <small class="text-muted">elementy</small>
                      </div>
                      <input type="hidden" name="parts_list" id="partsListHidden" value="[]">
                      <input type="hidden" name="missing_or_damaged_desc" id="missingOrDamagedHidden" value="[]">
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="col-12">
              <div class="section-card">
                <div class="row g-3">
                  <div class="col-12 col-lg-6">
                    <div class="mui-standard-field">
                      <label class="mui-label">Opis zgłoszenia</label>
                      <textarea name="description" class="mui-input-standard" rows="5" placeholder="Opis zgłoszenia"></textarea>
                    </div>
                  </div>
                  <div class="col-12 col-lg-6">
                    <div class="row g-2">
                      <div class="col-12 col-md-6">
                        <div class="mui-standard-field">
                          <label class="mui-label">Zdjęcia / wideo</label>
                          <input id="claimFilesInput" name="files" type="file" class="mui-input-standard" multiple>
                        </div>
                        <div id="claimUploadProgress" class="progress mt-2 d-none">
                          <div id="claimUploadBar" class="progress-bar" role="progressbar" style="width:0%">0%</div>
                        </div>
                      </div>
                      <div class="col-12 col-md-6">
                        <div id="claimFilesGallery" class="upload-preview mt-2"></div>
                        <small class="text-muted">Wgrane pliki</small>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="col-12 d-flex flex-wrap gap-2 justify-content-center">
              <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Zapisz</button>
              <button type="button" class="btn btn-light border border-secondary" data-bs-toggle="collapse" data-bs-target="#claimFormWrap">Anuluj</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <div class="table-responsive">
      <table class="table table-hover align-middle">
        <thead>
          <tr>
            <th style="width: 32px; font-size: 10px; font-weight: 400;">Rozwiń</th>
            <th style="font-size: 10px; font-weight: 400;">Dni</th>
            <th style="font-size: 10px; font-weight: 400;">Status</th>
            <th style="font-size: 10px; font-weight: 400;">Uwagi</th>
            <th style="font-size: 10px; font-weight: 400;">Nr zamówienia</th>
            <th style="font-size: 10px; font-weight: 400;">Klient</th>
            <th style="font-size: 10px; font-weight: 400;">Typ</th>
            <th style="font-size: 10px; font-weight: 400;">Data zgłoszenia</th>
            <th style="width: 50px; font-size: 10px; font-weight: 400;"></th>
          </tr>
        </thead>
        <tbody id="claimsBody"></tbody>
      </table>
    </div>

    <div class="d-flex justify-content-center align-items-center gap-2 mt-3">
      <button id="prevPage" class="btn btn-primary btn-sm" aria-label="Poprzednia strona">‹</button>
      <div id="pageInfo" class="text-muted small">-</div>
      <button id="nextPage" class="btn btn-primary btn-sm" aria-label="Następna strona">›</button>
    </div>

    <div class="card mt-4 d-none" id="detailCard">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3 detail-header-bar">
          <div class="d-flex align-items-center gap-3 flex-wrap">
            <h2 class="mb-0 detail-header-text">Szczegóły reklamacji</h2>
            <span class="detail-header-info" id="detailHeaderInfo"></span>
          </div>
          <div class="d-flex align-items-center gap-2">
            <span class="badge rounded-pill text-bg-primary" id="detailDays">0 dni</span>
            <button type="button" class="btn btn-sm btn-outline-danger" id="deleteClaimBtn" title="Usuń reklamację">
              <i class="bi bi-trash"></i> Usuń
            </button>
          </div>
        </div>
        <form id="detailForm" class="row g-3 detail-form-small">
          <input type="hidden" name="id">
          
          <!-- Pierwszy wiersz z dwoma boxami -->
          <div class="col-12">
            <div class="row g-3">
              <!-- Box 1: Status, Zamówienie, Typ reklamacji, Daty -->
              <div class="col-md-6">
                <div class="detail-box">
                  <div class="mui-standard-field mb-3">
                    <label class="mui-label">Status</label>
                    <select name="status" class="mui-input-standard">
                      <option value="">Status</option>
                    </select>
                  </div>
                  <div class="mui-standard-field mb-3">
                    <label class="mui-label">Zamówienie:</label>
                    <input name="order_no" type="text" class="mui-input-standard" placeholder="Numer zamówienia" required>
                  </div>
                  <div class="mui-standard-field mb-3">
                    <label class="mui-label">Typ reklamacji</label>
                    <select name="type" class="mui-input-standard" required>
                      <option value="">Typ reklamacji</option>
                    </select>
                  </div>
                  <div class="row g-2 mb-0">
                    <div class="col-6">
                      <div class="mui-standard-field">
                        <label class="mui-label">Data zgłoszenia</label>
                        <input name="reported_at" type="date" class="mui-input-standard" placeholder="Data zgłoszenia">
                      </div>
                    </div>
                    <div class="col-6">
                      <div class="mui-standard-field">
                        <label class="mui-label">Data zakupu</label>
                        <input name="purchase_date" type="date" class="mui-input-standard" placeholder="Data zakupu">
                      </div>
                    </div>
                  </div>
                </div>
              </div>
              
              <!-- Box 2: Imię nazwisko, Telefon Email, produkt, braki/wady -->
              <div class="col-md-6">
                <div class="detail-box">
                  <div class="mui-standard-field mb-3">
                    <label class="mui-label">Imię i nazwisko</label>
                    <input name="customer_name" type="text" class="mui-input-standard" placeholder="Imię i nazwisko" required>
                  </div>
                  <div class="row g-2 mb-3">
                    <div class="col-6">
                      <div class="mui-standard-field">
                        <label class="mui-label">Telefon</label>
                        <input name="phone" type="text" class="mui-input-standard" placeholder="Telefon (tylko cyfry)" inputmode="numeric" pattern="^[0-9]+$" required>
                      </div>
                    </div>
                    <div class="col-6">
                      <div class="mui-standard-field">
                        <label class="mui-label">Email</label>
                        <input name="email" type="email" class="mui-input-standard" placeholder="Email (kończy się na .pl lub .com)" pattern="^[^@\s]+@[^@\s]+\.(pl|com)$" required>
                      </div>
                    </div>
                  </div>
                  <div class="mui-standard-field mb-3">
                    <label class="mui-label">produkt</label>
                    <input name="product_model" type="text" class="mui-input-standard" placeholder="Model / wariant produktu" required>
                  </div>
                  <div class="mui-standard-field mb-0">
                    <label class="mui-label">braki/wady</label>
                    <input name="missing_or_damaged_desc" type="text" class="mui-input-standard" placeholder="Co brakuje / co jest uszkodzone" required>
                  </div>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Box 3: Podzielony na dwa boxy -->
          <div class="col-12">
            <div class="row g-3">
              <!-- Lewy box: Opis -->
              <div class="col-md-6">
                <div class="detail-box h-100 d-flex flex-column">
                  <div class="mui-standard-field mb-0 flex-grow-1 d-flex flex-column">
                    <label class="mui-label">Opis zgłoszenia</label>
                    <textarea name="description" class="mui-input-standard flex-grow-1" rows="3" placeholder="Opis zgłoszenia" style="min-height: 150px;"></textarea>
                  </div>
                </div>
              </div>
              <!-- Prawy box: Uwagi -->
              <div class="col-md-6">
                <div class="detail-box h-100 d-flex flex-column">
                  <div class="mui-standard-field mb-3">
                    <label class="mui-label">Co zrobiłem</label>
                    <textarea id="noteText" class="mui-input-standard" rows="3" placeholder="Dodaj krótką uwagę..."></textarea>
                  </div>
                  <div class="row g-2 mb-3">
                    <div class="col-6">
                      <div class="mui-standard-field">
                        <label class="mui-label">Data</label>
                        <input id="noteDate" type="date" class="mui-input-standard" placeholder="Data wpisu">
                      </div>
                    </div>
                    <div class="col-6 d-flex align-items-end">
                      <button type="button" id="addNoteBtn" class="btn btn-outline-primary w-100">Dodaj uwagę</button>
                    </div>
                  </div>
                  <div class="mui-standard-field mb-0 flex-grow-1 d-flex flex-column">
                    <label class="mui-label">Historia uwag</label>
                    <div id="notesList" class="small text-muted" style="max-height: 220px; overflow:auto;"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Box 3b: Decyzja, Data, Uzasadnienie (pod opisem) -->
          <div class="col-12">
            <div class="row g-3">
              <div class="col-md-6">
                <div class="detail-box h-100 d-flex flex-column">
                  <div class="row g-2 mb-3">
                    <div class="col-6">
                      <div class="mui-standard-field">
                        <label class="mui-label">Decyzja</label>
                        <select name="decision" class="mui-input-standard">
                          <option value="">Decyzja</option>
                        </select>
                      </div>
                    </div>
                    <div class="col-6">
                      <div class="mui-standard-field">
                        <label class="mui-label">Data zamknięcia</label>
                        <input name="closed_at" type="date" class="mui-input-standard" placeholder="Data zamknięcia">
                      </div>
                    </div>
                  </div>
                  <div class="mui-standard-field mb-0 flex-grow-1 d-flex flex-column">
                    <label class="mui-label">Uzasadnienie</label>
                    <textarea name="decision_reason" class="mui-input-standard flex-grow-1" rows="2" placeholder="Uzasadnienie decyzji" style="min-height: 150px;"></textarea>
                  </div>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Box 4: Części (2 kolumny) + Załączniki -->
          <div class="col-12">
            <div class="detail-box">
              <div class="row g-3">
                <!-- Części (lewy box) -->
                <div class="col-md-6">
                  <div class="row g-3">
                    <!-- Pasek dodawania części nad obiema kolumnami -->
                    <div class="col-12">
                      <div class="d-flex justify-content-center align-items-center mb-2">
                        <div class="part-add-group">
                          <input id="partName" type="text" class="form-control part-add-input" placeholder="Dodaj element do zgłoszenia">
                          <button id="addPartBtn" type="button" class="part-add-btn">Dodaj</button>
                        </div>
                      </div>
                    </div>
                    <!-- Kolumna: Części zgłoszone -->
                    <div class="col-12 col-md-6">
                      <h6 class="mb-2" style="font-size: 11px; font-weight: 600; color: #1976d2;">Części zgłoszone</h6>
                      <div id="partsList" class="mt-2"></div>
                    </div>
                    <!-- Kolumna: Części wysłane -->
                    <div class="col-12 col-md-6">
                      <h6 class="mb-2" style="font-size: 11px; font-weight: 600; color: #1976d2;">Części wysłane</h6>
                      <div id="partsListSent" class="mt-2"></div>
                    </div>
                  </div>
                </div>
                <!-- Załączniki (prawy box) -->
                <div class="col-md-6">
                  <input id="attachmentsInput" type="file" class="form-control" multiple>
                  <div class="mt-2" id="attachmentsList"></div>
                </div>
              </div>
            </div>
          </div>
          <div class="col-12 d-flex flex-wrap gap-2">
            <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Zapisz zmiany</button>
            <button type="button" class="btn btn-light" id="closeDetailBtn">Zamknij</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Modal potwierdzenia usuwania -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Potwierdzenie usunięcia</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p>Czy na pewno chcesz usunąć tę reklamację?</p>
        <p class="text-muted small mb-0">Ta operacja jest nieodwracalna i usunie również wszystkie załączniki.</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Anuluj</button>
        <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Usuń</button>
      </div>
    </div>
  </div>
</div>

<!-- Galeria załączników -->
<div id="galleryModal" class="gallery-modal" aria-hidden="true">
  <div class="gallery-content" id="galleryContentWrap">
    <button type="button" class="gallery-close" id="galleryClose">×</button>
    <button type="button" class="gallery-nav gallery-prev" id="galleryPrev">‹</button>
    <button type="button" class="gallery-nav gallery-next" id="galleryNext">›</button>
    <div id="galleryContent"></div>
  </div>
</div>

<script>
(function() {
  // Po załadowaniu wymuś start od góry strony
  window.scrollTo({ top: 0, behavior: 'auto' });
  const alertBox = document.getElementById('alertBox');
  const injectClaimStyles = () => {
    if (document.getElementById('claimRowStyles')) return;
    const style = document.createElement('style');
    style.id = 'claimRowStyles';
    style.textContent = `
      .table { font-size: 12px; }
      .claim-delete { border-color: transparent !important; background: transparent !important; }
      .claim-delete .bi-trash3-fill { color: #9ca3af; }
      .claim-delete:hover { background: #f5f5f5 !important; border-color: transparent !important; }
      .claim-delete:hover .bi-trash3-fill { color: #dc3545; }
    `;
    document.head.appendChild(style);
  };
  const updatedAt = document.getElementById('updatedAt');
  const refreshBtn = document.getElementById('refreshBtn');
  const searchInput = document.getElementById('searchInput');
  const statusFilter = document.getElementById('statusFilter');
  const typeFilter = document.getElementById('typeFilter');
  const claimsBody = document.getElementById('claimsBody');
  const pageInfo = document.getElementById('pageInfo');
  const prevPage = document.getElementById('prevPage');
  const nextPage = document.getElementById('nextPage');
  const claimForm = document.getElementById('claimForm');
  const detailCard = document.getElementById('detailCard');
  const detailForm = document.getElementById('detailForm');
  const missingField = detailForm ? detailForm.querySelector('[name="missing_or_damaged_desc"]') : null;
  const partsList = document.getElementById('partsList');
  const partName = document.getElementById('partName');
  const addPartBtn = document.getElementById('addPartBtn');
  const partsListSent = document.getElementById('partsListSent');
  const attachmentsInput = document.getElementById('attachmentsInput');
  const attachmentsList = document.getElementById('attachmentsList');
  const noteText = document.getElementById('noteText');
  const noteDate = document.getElementById('noteDate');
  const addNoteBtn = document.getElementById('addNoteBtn');
  const notesList = document.getElementById('notesList');
  const detailDays = document.getElementById('detailDays');
  const closeDetailBtn = document.getElementById('closeDetailBtn');
  const deleteClaimBtn = document.getElementById('deleteClaimBtn');
  const deleteConfirmModal = document.getElementById('deleteConfirmModal');
  const confirmDeleteBtn = document.getElementById('confirmDeleteBtn');
  let pendingDeleteId = null;
  const partsInput = document.getElementById('partsInput');
  const addPartBtnForm = document.getElementById('addPartBtnForm');
  const partsChips = document.getElementById('partsChips');
  const partsListHidden = document.getElementById('partsListHidden');
  const missingOrDamagedHidden = document.getElementById('missingOrDamagedHidden');
  const claimFilesInput = document.getElementById('claimFilesInput');
  const claimFilesGallery = document.getElementById('claimFilesGallery');
  const claimUploadProgress = document.getElementById('claimUploadProgress');
  const claimUploadBar = document.getElementById('claimUploadBar');

  let items = [];
  let filteredItems = [];
  let currentPage = 1;
  const pageSize = 20;
  let meta = { statuses: [], types: [], decisions: [] };
  let currentDetail = null;
  let parts = [];
  let selectedFiles = []; // Przechowuje wybrane pliki do uploadu

  const escapeHtml = (value) => (value || '')
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll("'", '&#39;');

  const formatDate = (iso) => {
    if (!iso) return '-';
    const date = new Date(iso);
    if (Number.isNaN(date.getTime())) return iso;
    return date.toLocaleDateString('pl-PL');
  };

  const setAlert = (message, type = 'danger') => {
    alertBox.textContent = message;
    alertBox.className = `alert alert-${type} ${message ? '' : 'd-none'}`;
  };

  const fullscreenNotice = (message, ms = 900) => {
    const overlay = document.createElement('div');
    overlay.style.position = 'fixed';
    overlay.style.inset = '0';
    overlay.style.background = 'rgba(0,0,0,0.75)';
    overlay.style.zIndex = '9999';
    overlay.style.display = 'flex';
    overlay.style.alignItems = 'center';
    overlay.style.justifyContent = 'center';
    overlay.style.textAlign = 'center';
    overlay.style.padding = '24px';
    const text = document.createElement('div');
    text.textContent = message;
    text.style.color = '#fff';
    text.style.font = '600 32px/1.25 system-ui, -apple-system, Segoe UI, Roboto, Arial';
    text.style.textShadow = '0 10px 40px rgba(0,0,0,0.6)';
    overlay.appendChild(text);
    document.body.appendChild(overlay);
    const close = () => { if (overlay && overlay.parentNode) overlay.remove(); };
    overlay.addEventListener('click', close, { once: true });
    setTimeout(close, ms);
  };

  const rocketSearchBtn = document.getElementById('rocketSearchBtn');
  const claimFormWrap = document.getElementById('claimFormWrap');

  const getClaimField = (name) => claimForm ? claimForm.querySelector(`[name="${name}"]`) : null;

  const setFieldValue = (field, value) => {
    if (!field) return;
    field.value = value ?? '';
    field.dispatchEvent(new Event('input', { bubbles: true }));
    field.dispatchEvent(new Event('change', { bubbles: true }));
  };

  const toDateInputValue = (value) => {
    const raw = (value || '').trim();
    if (!raw) return '';
    const pl = raw.match(/(\d{2})\.(\d{2})\.(\d{4})/);
    if (pl) return `${pl[3]}-${pl[2]}-${pl[1]}`;
    const iso = raw.match(/(\d{4})-(\d{2})-(\d{2})/);
    if (iso) return `${iso[1]}-${iso[2]}-${iso[3]}`;
    return '';
  };

  const openClaimForm = () => {
    if (!claimFormWrap) return;
    if (claimFormWrap.classList.contains('show')) return;
    if (window.bootstrap && window.bootstrap.Collapse) {
