  const deleteAttachment = async (id) => {
    if (!currentDetail) return;
    await fetch(`/api/reklamacje/${currentDetail.id}/attachments/${id}`, { method: 'DELETE' });
    // Odśwież tylko załączniki bez zamykania szczegółów
    const res = await fetch(`/api/reklamacje/${currentDetail.id}`);
    const data = await res.json();
    if (data.success && data.item) {
      currentDetail.attachments = data.item.attachments || [];
      renderAttachments(currentDetail.attachments);
    }
  };

  const deleteClaim = async (claimId, showConfirm = true) => {
    if (!claimId) return;
    
    if (showConfirm) {
      // Pokaż modal zamiast confirm()
      pendingDeleteId = claimId;
      if (window.bootstrap && deleteConfirmModal) {
        const modal = new bootstrap.Modal(deleteConfirmModal);
        modal.show();
      } else {
        // Fallback jeśli Bootstrap nie jest dostępny
        if (confirm(`Czy na pewno chcesz usunąć reklamację?\n\nTa operacja jest nieodwracalna i usunie również wszystkie załączniki.`)) {
          await performDelete(claimId);
        }
      }
      return;
    }
    
    await performDelete(claimId);
  };

  const performDelete = async (claimId) => {
    if (!claimId) return;
    
    setAlert('');
    try {
      const res = await fetch(`/api/reklamacje/${claimId}`, {
        method: 'DELETE',
      });
      const contentType = res.headers.get('content-type') || '';
      if (!contentType.includes('application/json')) {
        throw new Error(`Błąd serwera (${res.status})`);
      }
      const data = await res.json();
      if (!res.ok || !data.success) {
        throw new Error(data.error || 'Nie udało się usunąć reklamacji');
      }
      
      // Zamknij modal jeśli jest otwarty
      if (window.bootstrap && deleteConfirmModal) {
        const modal = bootstrap.Modal.getInstance(deleteConfirmModal);
        if (modal) modal.hide();
      }
      
      // Zamknij szczegóły jeśli były otwarte
      if (currentDetail && currentDetail.id === claimId) {
        detailCard.classList.add('d-none');
        currentDetail = null;
      }
      // Usuń zaznaczenie z wiersza
      document.querySelectorAll('.claim-row.selected').forEach(row => {
        row.classList.remove('selected');
      });
      
      // Odśwież listę
      await fetchClaims();
      setAlert('Reklamacja została usunięta.', 'success');
      pendingDeleteId = null;
    } catch (err) {
      setAlert(err.message || 'Błąd usuwania reklamacji');
      pendingDeleteId = null;
    }
  };

  claimsBody.addEventListener('click', (event) => {
    // Sprawdź czy kliknięto w przycisk usuwania lub ikonę kosza
    const deleteBtn = event.target.closest('.claim-delete');
    if (deleteBtn) {
      event.stopPropagation();
      event.preventDefault();
      const claimId = deleteBtn.dataset.id || deleteBtn.closest('[data-id]')?.dataset.id;
      if (claimId) {
        deleteClaim(claimId);
      }
      return;
    }
    
    // Sprawdź czy kliknięto w ikonę kosza (może być w <i>)
    if (event.target.closest('i.bi-trash') || event.target.closest('.bi-trash')) {
      event.stopPropagation();
      event.preventDefault();
      const btn = event.target.closest('.claim-delete') || event.target.closest('button');
      const claimId = btn?.dataset.id || btn?.closest('[data-id]')?.dataset.id;
      if (claimId) {
        deleteClaim(claimId);
      }
      return;
    }
    
    // Otwórz szczegóły przy kliknięciu w wiersz (ale nie w przycisk)
