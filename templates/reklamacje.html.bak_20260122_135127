  const uploadDetailAttachments = async () => {
    if (!currentDetail) return;
    const files = attachmentsInput.files;
    if (!files.length) return;
    await uploadAttachments(currentDetail.id, files);
    attachmentsInput.value = '';
    // Odśwież tylko załączniki bez zamykania szczegółów
    const res = await fetch(`/api/reklamacje/${currentDetail.id}`);
    const data = await res.json();
    if (data.success && data.item) {
      currentDetail.attachments = data.item.attachments || [];
      renderAttachments(currentDetail.attachments);
    }
