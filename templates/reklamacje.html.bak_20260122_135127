    if (!btn) return;
    removePart(Number(btn.dataset.index));
  });
  partsList.addEventListener('click', (event) => {
    // Kliknięcie na pigułkę, pole obok lub zielony znaczek przenosi do wysłanych
    const pill = event.target.closest('.part-pill-reported');
    if (pill) {
      movePartToSent(pill.dataset.id);
    }
  });
  // Globalny handler dla krzyżyka usuwania (działa dla obu list)
  document.addEventListener('click', (event) => {
    const btn = event.target.closest('.part-delete');
    if (!btn || !btn.dataset.id) return;
    event.preventDefault();
    event.stopPropagation();
    deleteDetailPart(btn.dataset.id);
  }, true);
  attachmentsList.addEventListener('click', (event) => {
    const btn = event.target.closest('.attachment-delete');
    if (btn) deleteAttachment(btn.dataset.id);
  });
  attachmentsList.addEventListener('click', (event) => {
    const thumb = event.target.closest('.upload-thumb');
    if (!thumb || event.target.closest('.attachment-delete')) return;
    const index = Number(thumb.dataset.index || 0);
    openGallery(index);
  });

  refreshBtn.addEventListener('click', fetchClaims);
  searchInput.addEventListener('input', applyFilters);
  statusFilter.addEventListener('change', applyFilters);
  typeFilter.addEventListener('change', applyFilters);
  prevPage.addEventListener('click', () => { currentPage -= 1; renderPage(); });
  nextPage.addEventListener('click', () => { currentPage += 1; renderPage(); });
  claimForm.addEventListener('submit', submitClaim);
  detailForm.addEventListener('submit', saveDetail);
  if (addNoteBtn) {
    addNoteBtn.addEventListener('click', addNote);
  }
  addPartBtn.addEventListener('click', addDetailPart);
  attachmentsInput.addEventListener('change', uploadDetailAttachments);
  claimFilesInput.addEventListener('change', () => {
    // Dodaj nowe pliki do listy (nie zastępuj istniejących)
    if (claimFilesInput.files && claimFilesInput.files.length) {
      [...claimFilesInput.files].forEach(file => {
        // Sprawdź czy plik już nie jest na liście (po nazwie i rozmiarze)
        const exists = selectedFiles.some(f => f.name === file.name && f.size === file.size);
        if (!exists) {
          selectedFiles.push(file);
        }
      });
    }
    renderFilePreviews(claimFilesGallery);
    // Wyczyść input, żeby można było wybrać te same pliki ponownie
    claimFilesInput.value = '';
  });
  closeDetailBtn.addEventListener('click', () => detailCard.classList.add('d-none'));
  deleteClaimBtn.addEventListener('click', () => {
    if (currentDetail && currentDetail.id) {
      deleteClaim(currentDetail.id);
    }
  });
  confirmDeleteBtn.addEventListener('click', () => {
    if (pendingDeleteId) {
      performDelete(pendingDeleteId);
    }
  });
  galleryClose?.addEventListener('click', closeGallery);
  galleryModal?.addEventListener('click', (event) => {
    if (event.target === galleryModal) closeGallery();
  });
  galleryPrev?.addEventListener('click', () => {
    if (!galleryItems.length) return;
    galleryIndex = (galleryIndex - 1 + galleryItems.length) % galleryItems.length;
    renderGalleryItem();
  });
  galleryNext?.addEventListener('click', () => {
    if (!galleryItems.length) return;
    galleryIndex = (galleryIndex + 1) % galleryItems.length;
    renderGalleryItem();
  });

  claimForm.reported_at.value = new Date().toISOString().slice(0, 10);
  initParts();
  fetchClaims();
})();
</script>

