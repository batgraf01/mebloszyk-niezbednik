      currentDetail = null;
      // Usuń zaznaczenie z wiersza
      document.querySelectorAll('.claim-row.selected').forEach(row => {
        row.classList.remove('selected');
        const icon = row.querySelector('.claim-caret-icon');
        if (icon) {
          icon.classList.remove('bi-caret-down-fill');
          icon.classList.add('bi-caret-right-fill');
          icon.style.color = 'rgb(174 174 174)';
        }
      });
      return;
    }
    
    setAlert('');
    try {
      const res = await fetch(`/api/reklamacje/${id}`);
      const data = await res.json();
      if (!res.ok || !data.success) throw new Error(data.error || 'Nie udało się pobrać szczegółów');
      currentDetail = data.item;
      detailCard.classList.remove('d-none');
      detailForm.reset();
      Object.keys(currentDetail).forEach(key => {
        const field = detailForm.elements.namedItem(key);
        if (!field) return;
        if (field.type === 'checkbox') {
          field.checked = Boolean(currentDetail[key]);
        } else {
          field.value = currentDetail[key] || '';
        }
      });
      detailDays.textContent = `${currentDetail.days_open} dni`;
      
      // Aktualizuj nagłówek z informacjami o reklamacji
      const orderNo = currentDetail.order_no || '';
      const purchaseDate = formatDateShort(currentDetail.purchase_date);
      const createdDate = formatDateShort(currentDetail.created_at);
      
      let infoParts = [];
      if (orderNo) {
        // Format: "Reklamacja nr: R-[order_no] z dnia: [purchase_date] z dnia: [created_at]"
        infoParts.push(`Reklamacja nr: <strong>R-${orderNo}</strong>`);
        if (purchaseDate) {
          infoParts.push(`z dnia: <strong>${purchaseDate}</strong>`);
        }
        if (createdDate) {
          infoParts.push(`z dnia: <strong>${createdDate}</strong>`);
        }
      }
      
      const detailHeaderInfo = document.getElementById('detailHeaderInfo');
      if (detailHeaderInfo) {
        detailHeaderInfo.innerHTML = infoParts.join(' ');
      }
      
      // Zaznacz wiersz na liście
      document.querySelectorAll('.claim-row.selected').forEach(row => {
        row.classList.remove('selected');
        const icon = row.querySelector('.claim-caret-icon');
        if (icon) {
          icon.classList.remove('bi-caret-down-fill');
          icon.classList.add('bi-caret-right-fill');
          icon.style.color = 'rgb(174 174 174)';
        }
      });
      const selectedRow = document.querySelector(`.claim-row[data-id="${id}"]`);
      if (selectedRow) {
        selectedRow.classList.add('selected');
        const icon = selectedRow.querySelector('.claim-caret-icon');
        if (icon) {
          icon.classList.remove('bi-caret-right-fill');
          icon.classList.add('bi-caret-down-fill');
          icon.style.color = 'rgb(192 119 218)';
        }
      }
      // scroll to details section
      setTimeout(() => {
        detailCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 50);
      
      renderDetailParts(currentDetail.parts || []);
      renderAttachments(currentDetail.attachments || []);
      renderNotes(currentDetail.notes || []);
      if (noteDate && !noteDate.value) {
        const today = new Date().toISOString().slice(0, 10);
        noteDate.value = today;
      }
      // ponów auto-uzupełnianie przy każdym otwarciu (do momentu ręcznej edycji)
      missingAutoFill = true;
      syncMissingWithParts();
