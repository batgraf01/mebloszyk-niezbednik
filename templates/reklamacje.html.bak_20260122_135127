  const renderDetailParts = (parts) => {
    // Bez elementów docelowych nie renderuj
    if (!partsList || !partsListSent) return;
    // Części zgłoszone (bez sent lub sent = false)
    const reportedParts = parts.filter(p => !p.sent);
    // Części wysłane (sent = true)
    const sentParts = parts.filter(p => p.sent);
    
    if (!reportedParts.length) {
      partsList.innerHTML = '<div class="text-muted small">Brak części.</div>';
    } else {
      partsList.innerHTML = reportedParts.map(part => `
        <div class="part-pill-reported" data-id="${part.id}" title="Kliknij, aby przenieść do wysłanych">
          <div class="badge part-badge part-badge-reported">
            <button type="button" class="part-delete part-delete-btn me-1" data-id="${part.id}" onclick="event.stopPropagation();">×</button>
            <span style="flex: 1; overflow: hidden; text-overflow: ellipsis;">${escapeHtml(part.part_name)}</span>
            <span class="ms-1 part-move-icon">✓</span>
          </div>
        </div>
      `).join('');
    }
    
    if (!sentParts.length) {
      partsListSent.innerHTML = '<div class="text-muted small">Brak części wysłanych.</div>';
    } else {
      partsListSent.innerHTML = sentParts.map(part => `
        <div class="part-pill">
          <div class="badge part-badge part-badge-sent">
            <button type="button" class="part-delete part-delete-btn me-1" data-id="${part.id}" onclick="event.stopPropagation();">×</button>
            <span style="flex: 1; overflow: hidden; text-overflow: ellipsis;">${escapeHtml(part.part_name)}</span>
          </div>
        </div>
      `).join('');
    }
    syncMissingWithParts();
  };

  const renderNotes = (notes) => {
    if (!notesList) return;
    if (!Array.isArray(notes) || !notes.length) {
      notesList.innerHTML = '<div class="text-muted">Brak uwag.</div>';
      return;
    }
    notesList.innerHTML = notes.map((note) => {
      const date = formatDateShort(note.note_date) || note.note_date || '';
      const text = escapeHtml(note.note_text || '');
      return `
        <div class="mb-2">
          <div class="text-muted" style="font-size:10px;">${date}</div>
          <div style="font-size:11px;">${text}</div>
        </div>
      `;
    }).join('');
  };

  const addNote = async () => {
    if (!currentDetail) return;
    const text = (noteText?.value || '').trim();
    const date = (noteDate?.value || '').trim();
    if (!text) {
      setAlert('Wpisz treść uwagi.', 'warning');
      return;
    }
    try {
      const res = await fetch(`/api/reklamacje/${currentDetail.id}/notes`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ note_text: text, note_date: date }),
      });
      const data = await res.json();
      if (!res.ok || !data.success) throw new Error(data.error || 'Nie udało się dodać uwagi');
      currentDetail.notes = data.notes || [];
      renderNotes(currentDetail.notes);
      if (noteText) noteText.value = '';
      if (noteDate) noteDate.value = '';
      setAlert('Dodano uwagę.', 'success');
      await fetchClaims();
    } catch (err) {
      setAlert(err.message || 'Błąd dodawania uwagi');
    }
  };

