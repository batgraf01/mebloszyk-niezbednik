  }

  const fillSelect = (select, options, label) => {
    if (!select) {
      console.error('fillSelect: select element is null');
      return;
    }
    if (!Array.isArray(options) || options.length === 0) {
      console.warn('fillSelect: options is not an array or is empty', options);
      select.innerHTML = `<option value="">${label}</option>`;
      return;
    }
    select.innerHTML = `<option value="">${label}</option>` + options.map(opt => `<option value="${escapeHtml(opt)}">${escapeHtml(opt)}</option>`).join('');
  };

  const syncHidden = () => {
    const json = JSON.stringify(parts);
    partsListHidden.value = json;
    missingOrDamagedHidden.value = json;
  };

  const renderParts = () => {
    if (!parts.length) {
      partsChips.innerHTML = '';
      syncHidden();
      return;
    }
    partsChips.innerHTML = parts.map((part, idx) => `
      <span class="parts-chip">
        ${escapeHtml(part)}
        <button type="button" aria-label="Usuń" data-index="${idx}">&times;</button>
      </span>
    `).join('');
    syncHidden();
  };

  const addPart = (rawValue) => {
    const value = (rawValue || '').trim();
    if (!value || value.length > 30 || parts.length >= 30) {
      return;
    }
    const exists = parts.some(p => p.toLowerCase() === value.toLowerCase());
    if (exists) return;
    parts.push(value);
    renderParts();
  };

  const removePart = (index) => {
    parts.splice(index, 1);
    renderParts();
