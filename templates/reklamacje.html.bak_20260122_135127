    const names = (currentDetail?.parts || [])
      .map(p => p.part_name)
      .filter(Boolean);
    missingField.value = names.join(', ');
  };

  const renderAttachments = (attachments) => {
    if (!attachmentsList) {
      console.error('attachmentsList not found');
      return;
    }
    if (!attachments || !attachments.length) {
      attachmentsList.innerHTML = '<div class="text-muted small">Brak załączników.</div>';
      attachmentsList.className = '';
      return;
    }
    console.log('renderAttachments:', attachments.length, 'attachments');
    attachmentsList.innerHTML = '';
    attachmentsList.className = 'upload-preview mt-2';
    attachments.forEach((att, index) => {
      const wrapper = document.createElement('div');
      wrapper.className = 'upload-thumb';
      wrapper.dataset.index = index;
      const url = `/api/reklamacje/${currentDetail.id}/attachments/${att.id}`;
      const ext = (att.original_name || '').split('.').pop().toLowerCase();
      if (['png', 'jpg', 'jpeg', 'gif', 'webp'].includes(ext)) {
        const img = document.createElement('img');
        img.src = url;
        wrapper.appendChild(img);
        const pop = document.createElement('div');
        pop.className = 'upload-pop';
        const big = document.createElement('img');
        big.src = url;
        pop.appendChild(big);
        wrapper.appendChild(pop);
      } else if (['mp4', 'avi', 'mov'].includes(ext)) {
        const video = document.createElement('video');
        video.src = url;
        video.muted = true;
        video.playsInline = true;
        wrapper.appendChild(video);
        const pop = document.createElement('div');
        pop.className = 'upload-pop';
        const big = document.createElement('video');
        big.src = url;
        big.muted = true;
        big.playsInline = true;
        big.autoplay = true;
        big.loop = true;
        pop.appendChild(big);
        wrapper.appendChild(pop);
      } else {
        wrapper.textContent = (att.original_name || '').slice(0, 12);
      }
      // Przycisk usuwania
      const removeBtn = document.createElement('button');
      removeBtn.type = 'button';
      removeBtn.className = 'attachment-delete attachment-delete-btn';
      removeBtn.dataset.id = att.id;
      removeBtn.textContent = '×';
      wrapper.style.position = 'relative';
      wrapper.appendChild(removeBtn);
      attachmentsList.appendChild(wrapper);
    });
    galleryItems = attachments.map((att) => ({
      id: att.id,
      url: `/api/reklamacje/${currentDetail.id}/attachments/${att.id}`,
      name: att.original_name || '',
    }));
